# Supabase — copy to .env.local and fill in.
# Local dev: run `npx supabase start` and paste the printed API URL + keys.
# Vercel/prod: use your project's values from the Supabase dashboard (Settings > API).

# Public — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL="http://127.0.0.1:54321"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Server only — NEVER expose to the client. Bypasses RLS. Used for user provisioning.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Base URL of the app (used for auth redirects)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
